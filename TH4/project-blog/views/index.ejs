<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trang chủ Blog</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
   <div class="container">
    <h1>Blog Của Tôi</h1>
    <div style="text-align: right; margin-bottom: 20px;">
        <a href="/blogposts/new" class="btn btn-primary">+ Viết bài mới</a>
    </div>
    <div class="post-list">
       <% posts.forEach(post => { %>
    <article class="post-card">
        <div class="post-card-content">
            <a href="/blogposts/<%= post._id %>" class="post-link">
                <!-- Đảm bảo post.title và post.body viết đúng tên trường trong Schema -->
                <h2><%= post.title %></h2> 
            </a>
            <p class="post-excerpt">
                <%= post.body ? post.body.substring(0, 150) : "Không có nội dung" %>...
            </p>
            <div class="post-footer">
                <a href="/blogposts/<%= post._id %>" class="view-more">Đọc thêm →</a>
            </div>
        </div>
    </article>
<% }) %>
    </div>
</div>

</body>
</html>
