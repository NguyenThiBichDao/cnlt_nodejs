<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tạo bài viết mới</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <div class="form-container" style="margin-top: 50px;">
        <h1>Tạo bài viết mới</h1>
        
        <form action="/blogposts/store" method="POST">
            <div style="margin-bottom: 20px;">
                <label>Tiêu đề:</label>
                <input type="text" name="title" placeholder="Nhập tiêu đề bài viết..." required>
            </div>

            <div style="margin-bottom: 20px;">
                <label>Nội dung:</label>
                <textarea name="body" rows="10" placeholder="Viết nội dung tại đây..." required></textarea>
            </div>

            <div style="display: flex; gap: 20px; align-items: center;">
                <!-- Nút Lưu bài viết nổi bật -->
                <button type="submit" class="btn-create" style="flex: 2; border: none; cursor: pointer;">
                    Lưu bài viết
                </button>
                
                <!-- Nút Hủy bỏ -->
                <a href="/" style="flex: 1; text-align: center; color: var(--text-muted); text-decoration: none; font-weight: 600;">
                    Hủy bỏ
                </a>
            </div>
        </form>
    </div>

</body>
</html>
