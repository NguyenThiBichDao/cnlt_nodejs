<%- include('partials/header') %>

<!-- Masthead (Phần giới thiệu đầu trang) -->
<header class="masthead">
    <div class="container">
        <div class="masthead-subheading">Chào mừng đến với cửa hàng của chúng tôi!</div>
        <div class="masthead-heading text-uppercase">Rất vui được gặp bạn</div>
        <a class="btn btn-primary btn-xl text-uppercase" href="#portfolio">Xem sản phẩm ngay</a>
    </div>
</header>

<!-- Services (Dịch vụ) -->
<section class="page-section" id="services">
    <div class="container">
        <div class="text-center">
            <h2 class="section-heading text-uppercase">Dịch vụ</h2>
            <h3 class="section-subheading text-muted">Chúng tôi cung cấp những giải pháp tốt nhất cho bạn.</h3>
        </div>
        <div class="row text-center">
            <div class="col-md-4">
                <span class="fa-stack fa-4x">
                    <i class="fas fa-circle fa-stack-2x text-primary"></i>
                    <i class="fas fa-shopping-cart fa-stack-1x fa-inverse"></i>
                </span>
                <h4 class="my-3">E-Commerce</h4>
                <p class="text-muted">Hệ thống mua sắm trực tuyến hiện đại, nhanh chóng và tiện lợi.</p>
            </div>
            <div class="col-md-4">
                <span class="fa-stack fa-4x">
                    <i class="fas fa-circle fa-stack-2x text-primary"></i>
                    <i class="fas fa-laptop fa-stack-1x fa-inverse"></i>
                </span>
                <h4 class="my-3">Giao diện tương thích</h4>
                <p class="text-muted">Trang web hiển thị tốt trên mọi thiết bị: máy tính, máy tính bảng, điện thoại.</p>
            </div>
            <div class="col-md-4">
                <span class="fa-stack fa-4x">
                    <i class="fas fa-circle fa-stack-2x text-primary"></i>
                    <i class="fas fa-lock fa-stack-1x fa-inverse"></i>
                </span>
                <h4 class="my-3">Bảo mật tuyệt đối</h4>
                <p class="text-muted">Dữ liệu khách hàng và giao dịch luôn được bảo vệ an toàn tối đa.</p>
            </div>
        </div>
    </div>
</section>

<!-- Portfolio Grid (Danh sách sản phẩm) -->
<section class="page-section bg-light" id="portfolio">
    <div class="container">
        <div class="text-center">
            <h2 class="section-heading text-uppercase">Danh sách sản phẩm</h2>
            <h3 class="section-subheading text-muted">Dữ liệu được lấy động từ Server (index.js)</h3>
        </div>
        <div class="row">
            <% dsSanPham.forEach(function(item) { %>
                <div class="col-lg-4 col-sm-6 mb-4">
                    <div class="portfolio-item">
                        <!-- Đường dẫn đến trang chi tiết động /detail/:id -->
                        <a class="portfolio-link" href="/detail/<%= item.id %>">
                            <div class="portfolio-hover">
                                <div class="portfolio-hover-content"><i class="fas fa-plus fa-3x"></i></div>
                            </div>
                            <!-- Hình ảnh lấy theo ID, nếu không có sẽ dùng ảnh mặc định 1.jpg -->
                            <img class="img-fluid" src="/assets/img/portfolio/<%= item.id %>.jpg" alt="<%= item.name %>" onerror="this.src='/assets/img/portfolio/1.jpg'" />
                        </a>
                        <div class="portfolio-caption">
                            <div class="portfolio-caption-heading">
                                <%= item.name %>
                                <% if (item.hot) { %>
                                    <span class="badge bg-danger" style="font-size: 0.5em; vertical-align: middle;">HOT</span>
                                <% } %>
                            </div>
                            <div class="portfolio-caption-subheading text-muted">Mã sản phẩm: #<%= item.id %></div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- About (Về chúng tôi) -->
<section class="page-section" id="about">
    <div class="container">
        <div class="text-center">
            <h2 class="section-heading text-uppercase">Về chúng tôi</h2>
            <h3 class="section-subheading text-muted">Lịch sử hình thành và phát triển.</h3>
        </div>
        <ul class="timeline">
            <li>
                <div class="timeline-image"><img class="rounded-circle img-fluid" src="assets/img/about/1.jpg" alt="..." /></div>
                <div class="timeline-panel">
                    <div class="timeline-heading">
                        <h4>2009-2011</h4>
                        <h4 class="subheading">Những bước đi đầu tiên</h4>
                    </div>
                    <div class="timeline-body"><p class="text-muted">Chúng tôi bắt đầu từ một cửa hàng nhỏ với niềm đam mê công nghệ cháy bỏng.</p></div>
                </div>
            </li>
            <li class="timeline-inverted">
                <div class="timeline-image"><img class="rounded-circle img-fluid" src="assets/img/about/2.jpg" alt="..." /></div>
                <div class="timeline-panel">
                    <div class="timeline-heading">
                        <h4>Tháng 3/2011</h4>
                        <h4 class="subheading">Mở rộng quy mô</h4>
                    </div>
                    <div class="timeline-body"><p class="text-muted">Thương hiệu chính thức ra mắt và nhận được sự tin tưởng từ hàng ngàn khách hàng.</p></div>
                </div>
            </li>
            <li class="timeline-inverted">
                <div class="timeline-image">
                    <h4>Be Part<br />Of Our<br />Story!</h4>
                </div>
            </li>
        </ul>
    </div>
</section>

<%- include('partials/footer') %>
